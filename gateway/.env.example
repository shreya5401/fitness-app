# Shared secret used by the gateway to sign requests to downstream services.
# Must match INTERNAL_API_SECRET in userservice, activityservice, and aiservice.
INTERNAL_API_SECRET=change-me

# Keycloak JWK set endpoint used to validate incoming JWTs (defaults to localhost if unset)
KEYCLOAK_JWK_SET_URI=http://localhost:8181/realms/fitness-oauth2/protocol/openid-connect/certs

# Origin allowed to call the gateway (defaults to localhost:5173 if unset)
CORS_ALLOWED_ORIGIN=http://localhost:5173

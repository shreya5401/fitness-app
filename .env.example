# Used by docker-compose.yml only (see docker-compose.yml for how these are wired to each service)

# Shared secret the gateway attaches to every request it forwards; must match across all services
INTERNAL_API_SECRET=change-me

# Local Postgres container credentials
POSTGRES_PASSWORD=postgres

# Local Keycloak admin console credentials (http://localhost:8181)
KEYCLOAK_ADMIN_PASSWORD=admin

# Google Gemini API credentials (https://ai.google.dev/)
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent?key=
GEMINI_API_KEY=<your-gemini-api-key>

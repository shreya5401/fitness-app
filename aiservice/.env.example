# MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fitnessrecommendation?appName=<app-name>

# Google Gemini API credentials (https://ai.google.dev/)
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent?key=

# Shared secret used to verify requests actually came from the gateway.
# Must match INTERNAL_API_SECRET in gateway, userservice, and activityservice.
INTERNAL_API_SECRET=change-me
